### Registro de un usuario
POST http://localhost:3000/auth/register
Content-Type: application/json

{
  "name": "Tu nombre",
  "email": "test@test.com",
  "password": "123456"
}

### Inicio de sesión de un usuario
POST http://localhost:3000/auth/login
Content-Type: application/json

{
  "email": "test@test.com",
  "password": "123456"
}

### Obtener todos los hábitos (SUSTITUIR <token> por el que nos devuelva el login)
GET http://localhost:3000/habits
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6IjZhNDYxNzg2ZjBkZGQwYmJhOTExNzlhOCIsImlhdCI6MTc4MzQxNjYzMywiZXhwIjoxNzgzNTAzMDMzfQ.-cSl1_hIjZw5p0Ld86k6Y8V3H8TI0m8tJYVCkUC8NPc

### Crear un hábito
POST http://localhost:3000/habits
Content-Type: application/json
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6IjZhNDYxNzg2ZjBkZGQwYmJhOTExNzlhOCIsImlhdCI6MTc4MzQxNjYzMywiZXhwIjoxNzgzNTAzMDMzfQ.-cSl1_hIjZw5p0Ld86k6Y8V3H8TI0m8tJYVCkUC8NPc

{
  "name": "Ejercicio",
  "category": "Salud",
  "color": "#6366f1",
  "targetFrequency": "daily",
  "timesPerPeriod": 1
}

### Editar un hábito
PUT http://localhost:3000/habits/<id>
Content-Type: application/json
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6IjZhNDYxNzg2ZjBkZGQwYmJhOTExNzlhOCIsImlhdCI6MTc4MzQxNjYzMywiZXhwIjoxNzgzNTAzMDMzfQ.-cSl1_hIjZw5p0Ld86k6Y8V3H8TI0m8tJYVCkUC8NPc

{
  "name": "Ejercicio actualizado",
  "category": "Salud",
  "color": "#6366f1",
  "targetFrequency": "weekly",
  "timesPerPeriod": 3
}

### Eliminar un hábito
DELETE http://localhost:3000/habits/<id>
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6IjZhNDYxNzg2ZjBkZGQwYmJhOTExNzlhOCIsImlhdCI6MTc4MzQxNjYzMywiZXhwIjoxNzgzNTAzMDMzfQ.-cSl1_hIjZw5p0Ld86k6Y8V3H8TI0m8tJYVCkUC8NPc

